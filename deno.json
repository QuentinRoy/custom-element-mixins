{
	"name": "@quentinroy/custom-element-mixins",
	"version": "0.4.1",
	"license": "MIT",
	"exports": "./source/index.ts",
	"publish": {
		"include": [
			"LICENSE",
			"README.md",
			"source/**/*.ts",
			"!source/**/*.test-d.ts",
			"!source/**/*.spec.ts"
		]
	},
	"tasks": {
		"test": "vitest run --typecheck",
		"test:watch": "vitest watch --typecheck",
		"lint": "biome check",
		"format": "biome format"
	},
	"nodeModulesDir": "auto",
	"imports": {
		"@biomejs/biome": "npm:@biomejs/biome@^2.4.9",
		"typescript": "npm:typescript@^6.0.2",
		"vitest": "npm:vitest@^4.1.2"
	}
}
